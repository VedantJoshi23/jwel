# Jwel API — environment template. Copy to `.env` and fill in.
#   cp .env.example .env
#
# Values are validated at boot by src/config/env.validation.ts. Anything marked
# REQUIRED (prod) crashes the app on startup if missing when NODE_ENV=production
# — deliberately, because each one fails silently and confusingly otherwise.

# ---------------------------------------------------------------- core
NODE_ENV=development
PORT=4000

# REQUIRED. Postgres connection string.
DATABASE_URL="postgresql://jwel:jwel@localhost:5432/jwel?schema=public"

# ---------------------------------------------------------------- auth
# REQUIRED. Generate with: openssl rand -base64 48
# Production rejects both the dev placeholder below and anything under 32 chars.
JWT_SECRET="local-dev-secret-not-for-production"
JWT_ACCESS_TOKEN_TTL="3600s"

# ---------------------------------------------------------------- web
# REQUIRED (prod). Comma-separated exact origins allowed to call the API.
# An empty value blocks every browser request while the API still boots — the
# single most confusing misconfiguration in this service, hence the hard check.
CORS_ALLOWED_ORIGINS="http://localhost:3000"

# Where OAuth callbacks redirect the browser after login.
FRONTEND_URL="http://localhost:3000"

# ---------------------------------------------------------------- storage
# `filesystem` writes to UPLOADS_DIR and serves via the API at /uploads/.
# `s3` uploads to AWS_S3_BUCKET and serves directly from S3/CDN.
STORAGE_PROVIDER=filesystem
UPLOADS_DIR=./uploads

# REQUIRED (prod). Public origin of THIS api, used to build media URLs that get
# handed to browsers. With filesystem storage every product image URL is built
# from this, so a localhost value in production means every image 404s. Must
# also be listed in apps/web/next.config.mjs `images.remotePatterns`.
PUBLIC_BASE_URL="http://localhost:4000"

# Only read when STORAGE_PROVIDER=s3. Credentials come from the AWS default
# chain (instance role / AWS_ACCESS_KEY_ID+AWS_SECRET_ACCESS_KEY), not from here.
# AWS_S3_BUCKET=
# AWS_REGION=
# CDN_BASE_URL=

# ---------------------------------------------------------------- payments
# Both must be set together. When absent the app boots with a mock provider and
# simulates payments; when NODE_ENV=production it refuses to start without them,
# so real orders can never be marked paid without money moving.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------- search
# Optional. Absent/unreachable Elasticsearch degrades to the Postgres search
# fallback (see SearchService) rather than failing.
# ELASTICSEARCH_NODE="http://localhost:9200"

# ---------------------------------------------------------------- oauth
# Optional. Each provider's routes return a 4xx until its pair is configured
# (see OAuthConfiguredGuard).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL="http://localhost:4000/api/v1/auth/google/callback"
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# FACEBOOK_CALLBACK_URL="http://localhost:4000/api/v1/auth/facebook/callback"
# APPLE_CLIENT_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=
# APPLE_CALLBACK_URL="http://localhost:4000/api/v1/auth/apple/callback"

# ---------------------------------------------------------------- admin bootstrap
# Read only by `pnpm admin:create` (scripts/create-admin.ts), never by the app.
# Creates or promotes the account the client uses to manage the catalogue.
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# ADMIN_NAME="Administrator"
