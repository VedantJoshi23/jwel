{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // Pinned explicitly. Without it TypeScript infers rootDir from the common
    // ancestor of all inputs, so adding any .ts file outside src/ (e.g.
    // scripts/create-admin.ts) silently relocates the output to dist/src/…,
    // breaking `start:prod` (node dist/main.js) and the Docker CMD.
    "rootDir": "./src"
  },
  "exclude": ["node_modules", "test", "dist", "scripts", "**/*spec.ts"]
}
